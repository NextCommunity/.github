[Unit]
Description=NextCommunity Leaderboard API
After=network.target

[Service]
Type=simple
User=appuser
Group=appuser
WorkingDirectory=/opt/nextcommunity-leaderboard
EnvironmentFile=/opt/nextcommunity-leaderboard/.env
ExecStart=/opt/nextcommunity-leaderboard/venv/bin/uvicorn backend.app.main:app --host 127.0.0.1 --port 8000
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
